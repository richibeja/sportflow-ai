{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/partido/:id*", "destination": "/index.html" },
    { "source": "/partido/(.*)", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/(css|js|images)/(.+)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
