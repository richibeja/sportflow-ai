{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/v567-final-stealth", "destination": "/index.html" },
    { "source": "/test-rewrite", "destination": "/handshake.html" },
    { "source": "/partido/:id", "destination": "/match-preview.html?id=:id" },
    { "source": "/partido/:id/:slug", "destination": "/match-preview.html?id=:id&slug=:slug" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ]
}
